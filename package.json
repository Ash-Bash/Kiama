{
  "name": "kiama",
  "version": "0.1.0",
  "description": "A decentralized Discord-like chat app",
  "main": "dist/server/kiama-server-0.1.0.js",
  "scripts": {
    "build": "npm --prefix src/server run build && npm --prefix src/client run build",
    "start": "npm --prefix src/server start",
    "build:server": "npm --prefix src/server run build",
    "build:client": "npm --prefix src/client run build",
    "build:auth": "npm --prefix src/auth run build",
    "start:server": "npm --prefix src/server start",
    "start:client": "npm --prefix src/client start",
    "start:auth": "npm --prefix src/auth start",
    "dev:server": "npm --prefix src/server run dev",
    "dev:client": "npm --prefix src/client run dev",
    "dev:auth": "npm --prefix src/auth run dev",
    "install:all": "npm install && npm --prefix src/server install && npm --prefix src/client install && npm --prefix src/auth install",
    "install-cli": "bash ./install"
    ,
    "package": "npm --prefix src/client run build && npm --prefix src/client run package --",
    "package:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false npm --prefix src/client run package --",
    "package:all": "npm --prefix src/client run package:all"
    ,"package:mac:universal": "npm --prefix src/client run package:mac:universal"
  },
  "keywords": [
    "chat",
    "decentralized",
    "discord-clone"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  }
}
