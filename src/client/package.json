{
  "name": "kiama-client",
  "version": "0.1.0",
  "description": "KIAMA client component",
  "main": "dist/client/main.js",
  "scripts": {
    "build": "npm run build:main && webpack --mode production",
    "postbuild": "node scripts/copyToBinaries.js",
    "build:main": "tsc --project tsconfig.main.json",
    "start": "electron ../../dist/client/main.js",
    "dev": "concurrently \"webpack --mode development --watch\" \"wait-on ../../dist/client/main.js && electron ../../dist/client/main.js\"",
    "prepackage": "rimraf ../../dist/binaries",
    "clean": "rimraf ../../dist/binaries",
    "package": "npm run build && node ./scripts/copyDistClient.js && electron-builder",
    "package:mac:universal": "npm run package -- --mac --universal",
    "package:all": "npm run package -- --mac --universal --win --linux --x64 --arm64"
  },
  "author": "",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "crypto-js": "^4.2.0",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "socket.io-client": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jszip": "^3.4.1",
    "@types/keytar": "^4.4.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.3",
    "electron-builder": "^24.0.0",
    "electron": "^25.0.0",
    "html-webpack-plugin": "^5.5.0",
    "node-loader": "^2.1.0",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0",
    "rimraf": "^6.1.2",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.0"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.kiama.app",
    "productName": "Kiama",
    "icon": "../../dist/binaries/icons/KiamaClient_256_Icon.png",
    "extraResources": [
      {
        "from": "../../dist/binaries/themes",
        "to": "themes",
        "filter": ["**/*"]
      },
      {
        "from": "../../dist/binaries/plugins",
        "to": "plugins",
        "filter": ["**/*"]
      },
      {
        "from": "../../dist/binaries/icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "../../dist/binaries/icons/KiamaClient_256_icon.ico"
    },
    "mac": {
      "icon": "../../dist/binaries/icons/KiamaClient_macOS_512_Icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ]
    },
    "linux": {
      "maintainer": "Ashley Chapman <xpsx.fan@gmail.com>",
      "icon": "../../dist/binaries/icons/KiamaClient_256_Icon.png",
      "category": "Network;Productivity;",
      "description": "Kiama desktop client",
      "target": [
        { "target": "AppImage", "arch": ["x64","arm64"] },
        { "target": "deb",     "arch": ["x64","arm64"] },
        { "target": "rpm",     "arch": ["x64","arm64"] }
      ],
      "asarUnpack": ["**/*.node","**/*.so"],
      "executableName": "kiama"
    },
    "directories": {
      "output": "../../dist/binaries"
    },
    "publish": {
      "provider": "github",
      "owner": "Ashley Chapman",
      "repo": "https://github.com/Ash-Bash/Kiama"
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "../../dist/binaries/icons/KiamaClient_256_Icon.png",
      "uninstallerIcon": "../../dist/binaries/icons/KiamaClient_256_Icon.png",
      "allowToChangeInstallationDirectory": true
    }
  }
}
