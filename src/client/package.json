{
  "name": "kiama-client",
  "version": "0.1.0",
  "description": "KIAMA client component",
  "main": "dist/client/main.js",
  "scripts": {
    "build": "npm run build:main && webpack --mode production",
    "postbuild": "node scripts/copyToBinaries.js",
    "build:main": "tsc --project tsconfig.main.json",
    "start": "electron ../../dist/client/main.js",
    "dev": "concurrently \"webpack --mode development --watch\" \"wait-on ../../dist/client/main.js && electron ../../dist/client/main.js\"",
    "package": "electron-builder",
    "package:mac:arm64": "electron-builder --mac --arm64",
    "package:mac:x64": "electron-builder --mac --x64",
    "package:mac:universal": "electron-builder --mac --universal",
    "package:win:x64": "electron-builder --win --x64",
    "package:win:ia32": "electron-builder --win --ia32",
    "package:linux:x64": "electron-builder --linux --x64",
    "package:linux:arm64": "electron-builder --linux --arm64",
    "package:all": "electron-builder --mac --win --linux --x64 --arm64"
  },
  "author": "",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "crypto-js": "^4.2.0",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "socket.io-client": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jszip": "^3.4.1",
    "@types/keytar": "^4.4.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.3",
    "electron-builder": "^24.0.0",
    "electron": "^25.0.0",
    "html-webpack-plugin": "^5.5.0",
    "node-loader": "^2.1.0",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.0"
  },
  "build": {
    "appId": "com.kiama.app",
    "productName": "Kiama",
    "files": [
      "package.json",
      {
        "from": "../../dist/client",
        "to": "dist/client"
      },
      "node_modules/**/*",
      "src/server/dist/**/*"
    ],
    "directories": {
      "output": "../../dist/binaries"
    },
    "extraResources": [
      {
        "from": "../../dist/binaries/themes",
        "to": "themes",
        "filter": ["**/*"]
      },
      {
        "from": "../../dist/binaries/plugins",
        "to": "plugins",
        "filter": ["**/*"]
      },
      {
        "from": "../../dist/binaries/icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "extraMetadata": {
      "main": "dist/client/main.js",
      "name": "Kiama"
    },
    "icon": "../../dist/binaries/icons/KiamaClient_256_Icon.png",
    "win": {
      "icon": "../../dist/binaries/icons/KiamaClient_256_icon.ico"
    },
    "linux": {
      "icon": "../../dist/binaries/icons/KiamaClient_256_Icon.png"
    },
    "mac": {
      "icon": "../../dist/binaries/icons/KiamaClient_macOS_512_Icon.png"
    }
  }
}
